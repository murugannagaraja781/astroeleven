<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml for FCM Incoming Call App

    WHY THESE PERMISSIONS EXIST:
    - INTERNET: Required for FCM and API calls
    - POST_NOTIFICATIONS: Required for Android 13+ to show any notifications
    - FOREGROUND_SERVICE: Required to keep call handling alive
    - FOREGROUND_SERVICE_PHONE_CALL: Android 14+ requires specific foreground service types
    - USE_FULL_SCREEN_INTENT: Allows full-screen intent on lock screen
    - VIBRATE: Vibrate device on incoming call
    - WAKE_LOCK: Keep CPU awake during call processing
    - RECEIVE_BOOT_COMPLETED: Optional - re-register FCM token after device reboot
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notification permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Full screen intent for lock screen (incoming call UI) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Ringtone and vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep CPU awake during call processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Optional: Re-register after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WebRTC Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Queries required for Android 11+ to open external UPI apps -->
    <queries>
        <package android:name="com.phonepe.app" />
        <package android:name="com.phonepe.app.business" />
        <package android:name="com.google.android.apps.nbu.paisa.user" />
        <package android:name="net.one97.paytm" />
        <package android:name="in.org.npci.upiapp" />
        <package android:name="com.whatsapp" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="upi" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="paytmmp" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="phonepe" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tez" />
        </intent>
    </queries>

    <!-- Declared to prevent AppOps attributionTag errors in Android 12+ logcat -->
    <attribution android:tag="default" android:label="@string/app_name" />
    <attribution android:tag="CallForegroundService" android:label="@string/app_name" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FCMCallApp"
        android:name=".AstrologerApp"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="35">

        
        <!-- ... existing activities ... -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FCMCallApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep Link for Automatic Referral -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="astroeleven" android:host="referral" />
                <data android:scheme="astro5" android:host="referral" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.guest.GuestDashboardActivity" />
        <activity android:name=".ui.academy.AcademyActivity" />
        <activity android:name=".ui.horoscope.FreeHoroscopeActivity" />
        <activity android:name=".ui.astro.AstrologerDashboardActivity" />
        <activity android:name=".ui.astro.AstrologerHistoryActivity" />
        <activity android:name=".ui.astro.PermissionActivity"
            android:theme="@style/Theme.FCMCallApp" />
        <activity android:name=".ui.admin.SuperPowerAdminDashboardActivity" android:exported="false" android:theme="@style/Theme.FCMCallApp"/>
        <activity android:name=".ui.settings.SettingsActivity" />
        <activity android:name=".ui.settings.ThemeSettingsActivity" />
        <activity android:name=".ui.rasipalan.RasipalanActivity" />
        <activity android:name=".ui.dashboard.GuestActivity" />
        <activity android:name=".ui.payment.PaymentActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="astroeleven"
                    android:host="payment-success"/>
            </intent-filter>
        </activity>
        <activity android:name=".ui.auth.LoginActivity" />
        <activity android:name=".ui.auth.OtpVerificationActivity" />
        <activity android:name=".ui.auth.AstrologerRegistrationActivity" />
        <activity android:name=".ui.support.FeedbackSupportActivity" />
        <activity android:name=".ui.rituals.RemediesActivity" />
        <activity android:name=".ui.home.HomeActivity" />
        <activity android:name=".ui.wallet.WalletActivity" />
        <activity android:name=".ui.wallet.SuperWalletActivity" />
        <activity android:name=".ui.chat.ChatActivity" android:windowSoftInputMode="adjustResize" android:launchMode="singleTop" android:showWhenLocked="true" android:turnScreenOn="true"/>
        <activity android:name=".ui.chat.FullScreenImageActivity" android:theme="@style/Theme.FCMCallApp" />
        <activity android:name=".ui.call.CallActivity"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />
        <activity android:name=".ui.intake.IntakeActivity" android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.chart.ChartDisplayActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.chart.VipChartActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.chart.MatchDisplayActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:screenOrientation="portrait"/>

        <activity android:name=".ui.city.CitySearchActivity"
            android:theme="@style/Theme.FCMCallApp" />

        <activity
            android:name=".ui.wallet.PaymentStatusActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.FCMCallApp">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="astroeleven" />
            </intent-filter>
        </activity>

        <activity
            android:name=".IncomingCallActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:theme="@style/Theme.FCMCallApp.FullScreen" />

        <service
            android:name=".FCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name=".CallForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall|microphone|camera" />

        <service
            android:name=".AstrologerStatusService"
            android:exported="false"
            android:foregroundServiceType="specialUse|dataSync">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                      android:value="Maintaining socket connection for astrologer availability status" />
        </service>

        <service
            android:name=".telecom.CallConnectionService"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="incoming_calls" />

        <activity
            android:name=".ui.profile.AstrologerProfileActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:theme="@style/Theme.FCMCallApp"/>

        <activity
            android:name=".ui.profile.UserProfileActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:theme="@style/Theme.FCMCallApp"/>
            
        <activity
            android:name=".ui.rituals.RitualDetailActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:theme="@style/Theme.FCMCallApp"/>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <meta-data android:name="com.facebook.sdk.ApplicationId" android:value="@string/facebook_app_id"/>
        <meta-data android:name="com.facebook.sdk.ClientToken" android:value="@string/facebook_client_token"/>
        <activity android:name="com.facebook.FacebookActivity"
            android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation"
            android:label="@string/app_name" />
        <activity
            android:name="com.facebook.CustomTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/fb_login_protocol_scheme" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".receiver.ChatActionReceiver"
            android:exported="false" />

    </application>

</manifest>
